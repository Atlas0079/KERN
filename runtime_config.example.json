{
  "env": {
    "USE_LLM": "1",
    "LLM_PROVIDER": "openai_compat",
    "LLM_BASE_URL": "https://api.aabao.top",
    "LLM_API_PREFIX": "/v1",
    "LLM_API_KEY": "REPLACE_ME",
    "LLM_PLANNER_MODEL": "gpt-4o-mini",
    "LLM_GROUNDER_MODEL": "gpt-4o-mini",
    "LOG_LEVEL": "warn",
    "LOG_CATEGORIES": "llm,interaction,executor,task",
    "LLM_TIMEOUT_SECONDS": "20",
    "LLM_MAX_RETRIES": "2",
    "LLM_RETRY_BACKOFF_SECONDS": "1.5",
    "LLM_FAILURE_THRESHOLD": "3",
    "LLM_FAILURE_COOLDOWN_TICKS": "60",
    "LLM_DEBUG_VIEW": "",
    "DIALOGUE_LOG_FULL": "1",
    "DIALOGUE_BUDGET_LIMIT_PER_LOCATION": "4",
    "MAX_TRIGGER_DEPTH": "4",
    "MAX_TICKS_DEFAULT_LLM": "15",
    "MAX_TICKS_DEFAULT_NO_LLM": "65",
    "WORLD_JSON": "Farm/World.json",
    "RECIPES_JSONS": "Recipes.json,Farm/Recipes.json",
    "REACTIONS_JSONS": "Reactions.json,Farm/Reactions.json",
    "ENTITIES_DIRS": "Entities,Farm/Entities",
    "MAX_TICKS": "50"
  }
}
