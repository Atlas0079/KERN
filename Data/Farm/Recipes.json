{
    "farm_plant_seed_tomato": {
        "verb": "PlantSeed",
        "planner_hint": "在空农田上播种。",
        "grounder_hint": "target_id 是空的 farmland。parameters 必须包含 seed_id，且在背包中。番茄种子会触发番茄生长。",
        "selector": {
            "type": "all",
            "conditions": [
                {
                    "type": "has_tag",
                    "target": "param:seed_id",
                    "tag": "seed"
                },
                {
                    "type": "not",
                    "condition": {
                        "type": "has_tag",
                        "target": "param:seed_id",
                        "tag": "blueberry"
                    }
                }
            ]
        },
        "condition": {
            "type": "all",
            "conditions": [
                {
                    "type": "has_tags",
                    "target": "target",
                    "tags": ["farmland"],
                    "match": "all"
                },
                {
                    "type": "inventory_contains",
                    "owner": "self",
                    "item_ref": "param:seed_id"
                },
                {
                    "type": "same_location",
                    "left": "self",
                    "right": "target"
                },
                {
                    "type": "not",
                    "condition": {
                        "type": "has_status",
                        "target": "target",
                        "status_id": "growing"
                    }
                },
                {
                    "type": "not",
                    "condition": {
                        "type": "has_status",
                        "target": "target",
                        "status_id": "ready_tomato"
                    }
                },
                {
                    "type": "not",
                    "condition": {
                        "type": "has_status",
                        "target": "target",
                        "status_id": "ready_blueberry"
                    }
                },
                {
                    "type": "not",
                    "condition": {
                        "type": "inventory_has_tag",
                        "owner": "target",
                        "tag": "item",
                        "min_count": 1
                    }
                }
            ]
        },
        "narrative_success": "{actor}在{target}上种下了种子",
        "narrative_fail": "{actor}想在{target}上播种，但失败了",
        "process": {
            "required_progress": 2,
            "assign_to": "self"
        },
        "outputs": [
            {
                "effect": "DestroyEntity",
                "target": "param:seed_id"
            },
            {
                "effect": "AddStatus",
                "target": "target",
                "status_id": "growing"
            },
            {
                "effect": "CreateTask",
                "assign_to": "target",
                "recipe": {
                    "verb": "GrowTomato",
                    "process": {
                        "required_progress": 8
                    },
                    "progression": {
                        "progressor": "Linear",
                        "params": {
                            "base_progress_per_tick": 1.0,
                            "add_terms": [],
                            "mul_terms": [
                                {
                                    "when": {
                                        "type": "has_status",
                                        "target": "self",
                                        "status_id": "watered"
                                    },
                                    "value": 2.0
                                }
                            ]
                        }
                    },
                    "outputs": [
                        {
                            "effect": "AddStatus",
                            "target": "target",
                            "status_id": "ready_tomato"
                        },
                        {
                            "effect": "RemoveStatus",
                            "target": "target",
                            "status_id": "growing"
                        },
                        {
                            "effect": "RemoveStatus",
                            "target": "target",
                            "status_id": "watered"
                        }
                    ]
                }
            }
        ]
    },
