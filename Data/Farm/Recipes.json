    "farm_sell_item": {
        "verb": "SellItem",
        "planner_hint": "把物品卖给商人换钱。",
        "grounder_hint": "target_id 是商人。parameters 必须包含 item_id（你要卖的物品）。",
        "condition": {
            "type": "all",
            "conditions": [
                {
                    "type": "has_tags",
                    "target": "target",
                    "tags": ["merchant"],
                    "match": "all"
                },
                {
                    "type": "has_component",
                    "target": "param:item_id",
                    "component": "ValuableComponent"
                },
                {
                    "type": "inventory_contains",
                    "owner": "self",
                    "item_ref": "param:item_id"
                },
                {
                    "type": "same_location",
                    "left": "self",
                    "right": "target"
                }
            ]
        },
        "narrative_success": "{actor}卖掉了物品",
        "narrative_fail": "{actor}想卖东西，但失败了",
        "process": {
            "required_progress": 0
        },
        "outputs": [
            {
                "effect": "ExchangeResources",
                "source": "self",
                "target": "target",
                "transfer_mode": "transfer",
                "consume_items": ["param:item_id"],
                "consume_money": 0,
                "produce_items": [],
                "produce_money": "eval_price"
            }
        ]
    },
    "farm_buy_item": {
        "verb": "BuyItem",
        "planner_hint": "向商人购买货架上的商品。",
        "grounder_hint": "target_id 是商人。parameters 必须包含 item_id（你想买的那个商品实体ID，它应该在商人的透明背包里且带有 commodity 标签）。",
        "condition": {
            "type": "all",
            "conditions": [
                {
                    "type": "has_tags",
                    "target": "target",
                    "tags": ["merchant"],
                    "match": "all"
                },
                {
                    "type": "has_tags",
                    "target": "param:item_id",
                    "tags": ["commodity"],
                    "match": "all"
                },
                {
                    "type": "inventory_contains",
                    "owner": "target",
                    "item_ref": "param:item_id"
                },
                {
                    "type": "same_location",
                    "left": "self",
                    "right": "target"
                }
            ]
        },
        "narrative_success": "{actor}购买了物品",
        "narrative_fail": "{actor}想买物品，但钱不够或商人不卖",
        "process": {
            "required_progress": 0
        },
        "outputs": [
            {
                "effect": "ExchangeResources",
                "source": "target",
                "target": "self",
                "transfer_mode": "transfer",
                "consume_items": ["param:item_id"],
                "consume_money": 0,
                "produce_items": [],
                "produce_money": "eval_price"
            },
            {
                "effect": "RemoveTag",
                "target": "param:item_id",
                "tag": "commodity"
            }
        ]
    },
    "farm_inspect_shop": {
        "verb": "InspectShop",
        "planner_hint": "查看售货机正在售卖什么东西。",
        "grounder_hint": "target_id 是售货机。",
        "condition": {
            "type": "all",
            "conditions": [
                {
                    "type": "has_tags",
                    "target": "target",
                    "tags": ["merchant"],
                    "match": "all"
                },
                {
                    "type": "same_location",
                    "left": "self",
                    "right": "target"
                }
            ]
