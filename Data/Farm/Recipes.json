    "farm_water_crop": {
        "verb": "WaterCrop",
        "planner_hint": "给正在生长的农田浇水，可以加速生长任务。",
        "grounder_hint": "target_id 必须是 farmland。自己背包里必须有水壶(watering_can)。如果地块已有 watered 状态，就不需要再浇水。",
        "condition": {
            "type": "all",
            "conditions": [
                {
                    "type": "has_tags",
                    "target": "target",
                    "tags": ["farmland"],
                    "match": "all"
                },
                {
                    "type": "has_status",
                    "target": "target",
                    "status_id": "growing"
                },
                {
                    "type": "inventory_has_tag",
                    "owner": "self",
                    "tag": "watering_can",
                    "min_count": 1
                },
                {
                    "type": "same_location",
                    "left": "self",
                    "right": "target"
                },
                {
                    "type": "not",
                    "condition": {
                        "type": "has_status",
                        "target": "target",
                        "status_id": "watered"
                    }
                }
            ]
        },
        "narrative_success": "{actor}给{target}浇了水",
        "narrative_fail": "{actor}想浇水，但失败了",
        "process": {
            "required_progress": 0
        },
        "outputs": [
            {
                "effect": "AddStatus",
                "target": "target",
                "status_id": "watered"
            }
        ]
    },
    "farm_harvest_tomato": {
        "verb": "HarvestCrop",
        "planner_hint": "在农田地块上收获成熟作物。",
        "grounder_hint": "target_id 必须是 farmland，且地块带有 ready_tomato 状态。",
        "condition": {
            "type": "all",
            "conditions": [
                {
                    "type": "has_tags",
                    "target": "target",
                    "tags": ["farmland"],
                    "match": "all"
                },
                {
                    "type": "has_status",
                    "target": "target",
                    "status_id": "ready_tomato"
                }
            ]
        },
        "narrative_success": "{actor}从{target}收获了作物",
        "narrative_fail": "{actor}想收获，但失败了",
        "process": {
            "required_progress": 0
        },
        "outputs": [
            {
                "effect": "CreateEntity",
                "template": "TomatoCrop",
                "destination": {
                    "type": "container",
                    "target": "self"
                }
            },
            {
                "effect": "RemoveStatus",
                "target": "target",
                "status_id": "ready_tomato"
            }
        ]
    },
