        "outputs": [
            {
                "effect": "EmitEvent",
                "event_type": "MessageBroadcasted",
                "payload": {
                    "source_ref": "target",
                    "message": "我这里有 番茄种子(10元) 、蓝莓种子(30元)和黄金水壶（100元），要买点什么吗？"
                }
            }
        ]
    },
    "farm_read_note": {
        "verb": "ReadNote",
        "planner_hint": "阅读教程或笔记，获取明确的玩法目标和流程提示。",
        "grounder_hint": "target_id 必须是带 readable 标签的可见实体（通常是背包里的教程笔记）。",
        "condition": {
            "type": "all",
            "conditions": [
                {
                    "type": "has_tags",
                    "target": "target",
                    "tags": ["readable"],
                    "match": "all"
                },
                {
                    "type": "any",
                    "conditions": [
                        {
                            "type": "inventory_contains",
                            "owner": "self",
                            "item_ref": "target"
                        },
                        {
                            "type": "same_location",
                            "left": "self",
                            "right": "target"
                        }
                    ]
                }
            ]
        },
        "narrative_success": "{actor}阅读了{target}",
        "narrative_fail": "{actor}想阅读{target}，但失败了",
        "process": {
            "required_progress": 0
        },
        "outputs": [
            {
                "effect": "EmitEvent",
                "event_type": "MessageBroadcasted",
                "payload": {
                    "source_ref": "target",
                    "message": "教程：你是农场玩法测试玩家。目标是尽快赚到300块。先去商店购买种子和工具，再回农田播种、浇水、生长、收获并卖出。"
                }
            }
        ]
    },
    "generic_take_item": {
        "verb": "TakeItem",
        "planner_hint": "把可见物品从来源容器拿到自己背包。商店货物请使用 BuyItem，而不是直接拿取。",
        "grounder_hint": "target_id 是要拿取的物品ID。parameters 必须包含 source_id。若 source_id 是售货机(merchant)，应改用 BuyItem。",
        "condition": {
            "type": "all",
            "conditions": [
                {
                    "type": "has_tags",
                    "target": "target",
                    "tags": ["item"],
                    "match": "all"
                },
                {
                    "type": "not",
                    "condition": {
                        "type": "inventory_contains",
                        "owner": "self",
                        "item_ref": "target"
                    }
                },
                {
                    "type": "not",
                    "condition": {
                        "type": "has_tags",
                        "target": "param:source_id",
                        "tags": ["merchant"],
                        "match": "all"
                    }
                },
                {
                    "type": "same_location",
                    "left": "self",
                    "right": "param:source_id"
                }
            ]
        },
        "narrative_success": "{actor}捡起了{target}",
        "narrative_fail": "{actor}想拿起{target}，但失败了：{reason}",
        "process": {
            "required_progress": 0
        },
        "outputs": [
            {
                "effect": "MoveEntity",
                "entity_ref": "target",
                "from_ref": "param:source_id",
                "to_ref": "self"
            }
        ]
    }
}
