{
    "weapon_reload_revolver": {
        "verb": "ReloadRevolver",
        "planner_hint": "给左轮装弹，通常用于准备后续射击。",
        "grounder_hint": "parameters 必须包含 weapon_id(左轮id) 与 bullet_id(子弹id)，两者都应来自 Inventory；weapon 需要带 revolver_unloaded。",
        "target_tags": ["revolver"],
        "narrative_success": "{actor}给左轮装填了一发子弹",
        "narrative_fail": "{actor}想给左轮装填子弹，但失败了：{reason}",
        "selector": {
            "type": "has_tag",
            "target": "param:bullet_id",
            "tag": "bullet"
        },
        "condition": {
            "type": "all",
            "conditions": [
                {
                    "type": "inventory_contains",
                    "owner": "self",
                    "item_ref": "target"
                },
                {
                    "type": "inventory_contains",
                    "owner": "self",
                    "item_ref": "param:bullet_id"
                },
                {
                    "type": "has_condition",
                    "target": "target",
                    "condition_id": "revolver_unloaded"
                }
            ]
        },
        "process": {
            "required_progress": 0
        },
        "outputs": [
            {
                "effect": "DestroyEntity",
                "target": "param:bullet_id"
            },
            {
                "effect": "AddCondition",
                "target": "target",
                "condition_id": "revolver_loaded"
            },
            {
                "effect": "RemoveCondition",
                "target": "target",
                "condition_id": "revolver_unloaded"
            }
        ]
    },
    "weapon_shoot_revolver": {
        "verb": "ShootRevolver",
        "planner_hint": "使用已上膛的左轮对目标进行致命射击。",
        "grounder_hint": "parameters 必须包含 weapon_id；weapon_id 需要是 Inventory 中带 revolver_loaded 条件的左轮。",
        "target_tags": ["agent"],
        "narrative_success": "{actor}用左轮射杀了{target}",
        "narrative_fail": "{actor}想用左轮射击{target}，但失败了：{reason}",
        "condition": {
            "type": "all",
            "conditions": [
                {
                    "type": "has_tag",
                    "target": "param:weapon_id",
                    "tag": "revolver"
                },
                {
                    "type": "inventory_contains",
                    "owner": "self",
                    "item_ref": "param:weapon_id"
                },
                {
                    "type": "has_condition",
                    "target": "param:weapon_id",
                    "condition_id": "revolver_loaded"
                }
            ]
        },
        "process": {
            "required_progress": 0
        },
        "outputs": [
            {
                "effect": "RemoveCondition",
                "target": "param:weapon_id",
                "condition_id": "revolver_loaded"
            },
            {
                "effect": "AddCondition",
                "target": "param:weapon_id",
                "condition_id": "revolver_unloaded"
            },
            {
                "effect": "ModifyProperty",
                "target": "target",
                "component": "CreatureComponent",
                "property": "current_hp",
                "change": -9999
            }
        ]
    },
